# ── APEX Backend Environment Variables ────────────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to version control.

# App
APP_NAME="APEX — AI Physique Analyzer"
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:Ace117..@localhost:5432/apex_db

# JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_REAL_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
